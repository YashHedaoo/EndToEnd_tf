# Dynatrace Environment URL (e.g., https://xyz123.live.dynatrace.com)
dynatrace_url = "https://xyz123.live.dynatrace.com"

# Dynatrace PaaS/Installer Token with download permission for the OneAgent script
dynatrace_paas_token = "dt0c01.your-paas-token-value"

# The AWS Account ID of the target account being monitored
aws_account_id = "123456789012"

# The AWS region to deploy monitoring infrastructure and configurations
aws_region = "us-east-1"

# The name of the ECS cluster to create
cluster_name = "ecs-oneagent-cluster-test"

# The EC2 instance type for the ECS hosts
instance_type = "t3.medium"
